<%- include('_head') %>

<h1 class="text-3xl font-bold text-brand mb-6">登录</h1>

<div class="max-w-md">
  <form class="bg-white rounded-lg shadow p-8" action="/login" method="POST">
    <div class="mb-5">
      <label for="email" class="block font-semibold mb-1.5 text-warm-text">邮箱</label>
      <input type="email" id="email" name="email"
             value="<%= formData && formData.email || '' %>" required
             placeholder="请输入邮箱地址"
             autocomplete="email"
             class="w-full px-3 py-2.5 border border-gray-300 rounded text-base font-inherit transition-colors focus:outline-none focus:border-brand focus:ring-2 focus:ring-brand/15">
    </div>

    <div class="mb-5">
      <label for="password" class="block font-semibold mb-1.5 text-warm-text">密码</label>
      <input type="password" id="password" name="password"
             required
             placeholder="请输入密码"
             autocomplete="current-password"
             class="w-full px-3 py-2.5 border border-gray-300 rounded text-base font-inherit transition-colors focus:outline-none focus:border-brand focus:ring-2 focus:ring-brand/15">
    </div>

    <div class="flex gap-3 mt-6">
      <button type="submit" class="inline-block px-4 py-2 bg-brand text-white border-none rounded text-sm font-medium cursor-pointer hover:bg-brand-dark transition-colors font-inherit">登录</button>
    </div>
  </form>

  <p class="mt-5 text-warm-muted text-center">
    还没有账号？<a href="/register" class="text-brand no-underline font-medium hover:underline">立即注册 →</a>
  </p>
</div>

<%- include('_foot') %>
