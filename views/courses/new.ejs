<%- include('../_head') %>

<h2 class="page-title">新建课程</h2>

<div id="errorBox" class="error-box" style="display:none"></div>

<form class="crud-form" id="createForm">
  <div class="form-group">
    <label for="title">课程标题</label>
    <input type="text" id="title" name="title"
           placeholder="例如：法式甜点基础" required>
  </div>

  <div class="form-group">
    <label for="description">课程描述</label>
    <textarea id="description" name="description" rows="4"
              placeholder="简要描述课程内容" required></textarea>
  </div>

  <div class="form-group">
    <label for="duration">课程时长</label>
    <input type="text" id="duration" name="duration"
           placeholder="例如：8 周 • 初级" required>
  </div>

  <div class="form-group">
    <label for="cost">价格（¥）</label>
    <input type="number" id="cost" name="cost" min="0" step="0.01"
           placeholder="例如：399" required>
  </div>

  <div class="form-actions">
    <button type="submit" class="btn btn-primary">保存</button>
    <a href="/admin/courses" class="btn btn-cancel">取消</a>
  </div>
</form>

<script>
document.getElementById('createForm').addEventListener('submit', async function(e) {
  e.preventDefault();
  const formData = new FormData(this);
  const data = Object.fromEntries(formData.entries());
  const resp = await fetch('/admin/courses', {
    method: 'POST',
    body: JSON.stringify(data),
    headers: { 'Content-Type': 'application/json' },
  });
  const result = await resp.json();
  if (result.ok) {
    window.location.href = result.redirect;
  } else if (result.errors) {
    var box = document.getElementById('errorBox');
    box.style.display = 'block';
    box.innerHTML = result.errors.map(function(e) {
      return '<p>' + (e.field ? '<strong>' + e.field + '</strong>：' : '') + e.message + '</p>';
    }).join('');
  }
});
</script>

<%- include('../_foot') %>
