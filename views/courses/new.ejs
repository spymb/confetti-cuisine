<%- include('../_head') %>

<h1 class="text-3xl font-bold text-brand mb-6">新建课程</h1>

<div id="errorBox" class="bg-red-50 text-brand border border-red-200 rounded p-3 mb-4 max-w-lg hidden"></div>

<form class="bg-white rounded-lg shadow p-8 max-w-lg" id="createForm">
  <div class="mb-5">
    <label for="title" class="block font-semibold mb-1.5 text-warm-text">课程标题</label>
    <input type="text" id="title" name="title"
           placeholder="例如：法式甜点基础" required
           class="w-full px-3 py-2.5 border border-gray-300 rounded text-base font-inherit transition-colors focus:outline-none focus:border-brand focus:ring-2 focus:ring-brand/15">
  </div>

  <div class="mb-5">
    <label for="description" class="block font-semibold mb-1.5 text-warm-text">课程描述</label>
    <textarea id="description" name="description" rows="4"
              placeholder="简要描述课程内容" required
              class="w-full px-3 py-2.5 border border-gray-300 rounded text-base font-inherit transition-colors focus:outline-none focus:border-brand focus:ring-2 focus:ring-brand/15 resize-y min-h-[100px]"></textarea>
  </div>

  <div class="mb-5">
    <label for="duration" class="block font-semibold mb-1.5 text-warm-text">课程时长</label>
    <input type="text" id="duration" name="duration"
           placeholder="例如：8 周 • 初级" required
           class="w-full px-3 py-2.5 border border-gray-300 rounded text-base font-inherit transition-colors focus:outline-none focus:border-brand focus:ring-2 focus:ring-brand/15">
  </div>

  <div class="mb-5">
    <label for="cost" class="block font-semibold mb-1.5 text-warm-text">价格（¥）</label>
    <input type="number" id="cost" name="cost" min="0" step="0.01"
           placeholder="例如：399" required
           class="w-full px-3 py-2.5 border border-gray-300 rounded text-base font-inherit transition-colors focus:outline-none focus:border-brand focus:ring-2 focus:ring-brand/15">
  </div>

  <div class="flex gap-3 mt-6">
    <button type="submit" class="inline-block px-4 py-2 bg-brand text-white border-none rounded text-sm font-medium cursor-pointer hover:bg-brand-dark transition-colors font-inherit">保存</button>
    <a href="/admin/courses" class="inline-block px-4 py-2 bg-gray-400 text-white no-underline rounded text-sm font-medium hover:bg-gray-500 transition-colors">取消</a>
  </div>
</form>

<script>
document.getElementById('createForm').addEventListener('submit', async function(e) {
  e.preventDefault();
  const formData = new FormData(this);
  const data = Object.fromEntries(formData.entries());
  const resp = await fetch('/admin/courses', {
    method: 'POST',
    body: JSON.stringify(data),
    headers: { 'Content-Type': 'application/json' },
  });
  const result = await resp.json();
  if (result.ok) {
    window.location.href = result.redirect;
  } else if (result.errors) {
    var box = document.getElementById('errorBox');
    box.classList.remove('hidden');
    box.innerHTML = result.errors.map(function(e) {
      return '<p>' + (e.field ? '<strong>' + e.field + '</strong>：' : '') + e.message + '</p>';
    }).join('');
  }
});
</script>

<%- include('../_foot') %>
