<%- include('../_head') %>

<div class="flex justify-between items-center mb-4">
  <h1 class="text-3xl font-bold text-brand">课程管理</h1>
  <a href="/admin/courses/new" class="inline-block px-4 py-2 bg-brand text-white no-underline rounded text-sm font-medium hover:bg-brand-dark transition-colors">＋ 新建课程</a>
</div>

<% if (courses.length === 0) { %>
  <p class="text-warm-muted">暂无课程。</p>
<% } else { %>
  <table class="w-full border-collapse bg-white rounded-lg shadow overflow-hidden mb-6">
    <thead>
      <tr class="bg-brand text-white">
        <th class="px-4 py-3 text-left">标题</th>
        <th class="px-4 py-3 text-left">时长</th>
        <th class="px-4 py-3 text-left">价格</th>
        <th class="px-4 py-3 text-left">操作</th>
      </tr>
    </thead>
    <tbody>
      <% courses.forEach(function(c) { %>
        <tr class="even:bg-warm-bg hover:bg-brand-light transition-colors">
          <td class="px-4 py-3"><a href="/admin/courses/<%= c._id %>" class="text-brand no-underline font-medium hover:underline"><%= c.title %></a></td>
          <td class="px-4 py-3"><%= c.duration %></td>
          <td class="px-4 py-3">¥<%= c.cost %></td>
          <td class="px-4 py-3">
            <div class="flex gap-1.5">
              <a href="/admin/courses/<%= c._id %>" class="inline-block px-3 py-1.5 bg-blue-500 text-white no-underline rounded text-sm hover:bg-blue-600 transition-colors">查看</a>
              <a href="/admin/courses/<%= c._id %>/edit" class="inline-block px-3 py-1.5 bg-amber-500 text-white no-underline rounded text-sm hover:bg-amber-600 transition-colors">编辑</a>
              <button onclick="remove('<%= c._id %>')" class="inline-block px-3 py-1.5 bg-red-500 text-white border-none rounded text-sm cursor-pointer hover:bg-red-600 transition-colors font-inherit">删除</button>
            </div>
          </td>
        </tr>
      <% }); %>
    </tbody>
  </table>
<% } %>

<script>
async function remove(id) {
  if (!confirm('确定要删除该课程吗？')) return;
  var resp = await fetch('/admin/courses/' + id, { method: 'DELETE' });
  var result = await resp.json();
  if (result.ok) window.location.href = result.redirect;
}
</script>

<%- include('../_foot') %>
