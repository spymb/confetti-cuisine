<%- include('../_head') %>

<div class="bg-white rounded-lg shadow p-8 mb-6">
  <h1 class="text-brand text-2xl font-bold mb-4"><%= user.name %></h1>

  <dl class="grid grid-cols-[120px_1fr] gap-x-4 gap-y-2">
    <dt class="font-semibold text-warm-muted">邮箱</dt>
    <dd><%= user.email %></dd>
    <dt class="font-semibold text-warm-muted">注册时间</dt>
    <dd><%= new Date(user.createdAt).toLocaleString('zh-CN') %></dd>
    <dt class="font-semibold text-warm-muted">更新时间</dt>
    <dd><%= new Date(user.updatedAt).toLocaleString('zh-CN') %></dd>
  </dl>
</div>

<div class="bg-white rounded-lg shadow p-8 mb-6">
  <h2 class="text-brand text-lg font-bold mb-4">已报名课程</h2>
  <% if (user.enrolledCourses && user.enrolledCourses.length) { %>
    <table class="w-full border-collapse bg-white rounded-lg shadow overflow-hidden">
      <thead>
        <tr class="bg-brand text-white">
          <th class="px-4 py-3 text-left">课程名称</th>
          <th class="px-4 py-3 text-left">时长</th>
          <th class="px-4 py-3 text-left">价格</th>
        </tr>
      </thead>
      <tbody>
        <% user.enrolledCourses.forEach(function(c) { %>
          <tr class="even:bg-warm-bg hover:bg-brand-light transition-colors">
            <td class="px-4 py-3"><%= c.title %></td>
            <td class="px-4 py-3"><%= c.duration %></td>
            <td class="px-4 py-3">¥<%= c.cost %></td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  <% } else { %>
    <p class="text-warm-muted">暂无报名课程。</p>
  <% } %>
</div>

<div class="bg-white rounded-lg shadow p-8 mb-6">
  <h2 class="text-brand text-lg font-bold mb-4">订阅信息</h2>
  <% if (user.subscriberProfile) { %>
    <dl class="grid grid-cols-[120px_1fr] gap-x-4 gap-y-2">
      <dt class="font-semibold text-warm-muted">姓名</dt>
      <dd><%= user.subscriberProfile.name %></dd>
      <dt class="font-semibold text-warm-muted">邮箱</dt>
      <dd><%= user.subscriberProfile.email %></dd>
      <dt class="font-semibold text-warm-muted">邮编</dt>
      <dd><%= user.subscriberProfile.zipCode || '—' %></dd>
    </dl>
  <% } else { %>
    <p class="text-warm-muted">未关联订阅者。</p>
  <% } %>
</div>

<% if (locals.readOnly) { %>
  <div class="flex gap-3 mt-4">
    <a href="/" class="inline-block px-3 py-1.5 bg-gray-400 text-white no-underline rounded text-sm hover:bg-gray-500 transition-colors">返回首页</a>
  </div>
<% } else { %>
  <div class="flex gap-3 mt-4">
    <a href="/admin/users/<%= user._id %>/edit" class="inline-block px-3 py-1.5 bg-amber-500 text-white no-underline rounded text-sm hover:bg-amber-600 transition-colors">编辑</a>
    <button onclick="remove('<%= user._id %>')" class="inline-block px-3 py-1.5 bg-red-500 text-white border-none rounded text-sm cursor-pointer hover:bg-red-600 transition-colors font-inherit">删除</button>
    <a href="/admin/users" class="inline-block px-3 py-1.5 bg-gray-400 text-white no-underline rounded text-sm hover:bg-gray-500 transition-colors">返回列表</a>
  </div>

  <script>
  async function remove(id) {
    if (!confirm('确定要删除该用户吗？')) return;
    var resp = await fetch('/admin/users/' + id, { method: 'DELETE' });
    var result = await resp.json();
    if (result.ok) window.location.href = result.redirect;
  }
  </script>
<% } %>

<%- include('../_foot') %>
