<%- include('../_head') %>

<h1 class="text-3xl font-bold text-brand mb-6">编辑用户</h1>

<div id="errorBox" class="bg-red-50 text-brand border border-red-200 rounded p-3 mb-4 max-w-lg hidden"></div>

<form class="bg-white rounded-lg shadow p-8 max-w-lg" id="editForm">
  <div class="mb-5">
    <label for="name" class="block font-semibold mb-1.5 text-warm-text">姓名</label>
    <input type="text" id="name" name="name"
           value="<%= user.name %>" required
           class="w-full px-3 py-2.5 border border-gray-300 rounded text-base font-inherit transition-colors focus:outline-none focus:border-brand focus:ring-2 focus:ring-brand/15">
  </div>

  <div class="mb-5">
    <label for="email" class="block font-semibold mb-1.5 text-warm-text">邮箱（不可修改）</label>
    <input type="email" id="email" name="email"
           value="<%= user.email %>" readonly
           class="w-full px-3 py-2.5 border border-gray-300 rounded text-base font-inherit bg-gray-100 text-gray-500">
    <small class="text-gray-400">邮箱是登录凭据，管理员不可修改。如需变更请直接操作数据库。</small>
  </div>

  <div class="mb-5">
    <label for="enrolledCourses" class="block font-semibold mb-1.5 text-warm-text">已报名课程</label>
    <select id="enrolledCourses" name="enrolledCourses" multiple
            class="w-full px-3 py-2.5 border border-gray-300 rounded text-base font-inherit transition-colors focus:outline-none focus:border-brand focus:ring-2 focus:ring-brand/15 min-h-[120px]">
      <%
        var selectedIds = (user && user.enrolledCourses) ? user.enrolledCourses.map(function(id) { return String(id); }) : [];
      %>
      <% allCourses.forEach(function(c) { %>
        <option value="<%= c._id %>" <%= selectedIds.includes(String(c._id)) ? 'selected' : '' %>><%= c.title %></option>
      <% }); %>
    </select>
    <small class="text-gray-400">按住 Ctrl（Mac 上 Cmd）可多选</small>
  </div>

  <div class="mb-5">
    <label for="subscriberProfile" class="block font-semibold mb-1.5 text-warm-text">关联订阅者</label>
    <select id="subscriberProfile" name="subscriberProfile"
            class="w-full px-3 py-2.5 border border-gray-300 rounded text-base font-inherit transition-colors focus:outline-none focus:border-brand focus:ring-2 focus:ring-brand/15">
      <option value="">— 无 —</option>
      <% var selectedSub = user && user.subscriberProfile ? String(user.subscriberProfile) : ''; %>
      <% allSubscribers.forEach(function(s) { %>
        <option value="<%= s._id %>" <%= selectedSub === String(s._id) ? 'selected' : '' %>><%= s.name %>（<%= s.email %>）</option>
      <% }); %>
    </select>
  </div>

  <div class="flex gap-3 mt-6">
    <button type="submit" class="inline-block px-4 py-2 bg-brand text-white border-none rounded text-sm font-medium cursor-pointer hover:bg-brand-dark transition-colors font-inherit">保存</button>
    <a href="/admin/users/<%= user._id %>" class="inline-block px-4 py-2 bg-gray-400 text-white no-underline rounded text-sm font-medium hover:bg-gray-500 transition-colors">取消</a>
  </div>
</form>

<script>
document.getElementById('editForm').addEventListener('submit', async function(e) {
  e.preventDefault();
  var formData = new FormData(this);
  var data = Object.fromEntries(formData.entries());
  data.enrolledCourses = formData.getAll('enrolledCourses');
  var resp = await fetch('/admin/users/<%= user._id %>', {
    method: 'PUT',
    body: JSON.stringify(data),
    headers: { 'Content-Type': 'application/json' },
  });
  var result = await resp.json();
  if (result.ok) {
    window.location.href = result.redirect;
  } else if (result.errors) {
    var box = document.getElementById('errorBox');
    box.classList.remove('hidden');
    box.innerHTML = result.errors.map(function(e) {
      return '<p>' + (e.field ? '<strong>' + e.field + '</strong>：' : '') + e.message + '</p>';
    }).join('');
  }
});
</script>

<%- include('../_foot') %>
