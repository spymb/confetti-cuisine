<%- include('../_head') %>

<div class="detail-card">
  <h1><%= subscriber.name %></h1>

  <dl>
    <dt>邮箱</dt>
    <dd><%= subscriber.email %></dd>
    <dt>邮编</dt>
    <dd><%= subscriber.zipCode || '—' %></dd>
    <dt>订阅时间</dt>
    <dd><%= new Date(subscriber.createdAt).toLocaleString('zh-CN') %></dd>
    <dt>更新时间</dt>
    <dd><%= new Date(subscriber.updatedAt).toLocaleString('zh-CN') %></dd>
  </dl>

  <div class="detail-actions">
    <a href="/admin/subscribers/<%= subscriber._id %>/edit" class="btn btn-edit">编辑</a>
    <button onclick="remove('<%= subscriber._id %>')" class="btn btn-delete">删除</button>
    <a href="/admin/subscribers" class="btn btn-cancel">返回列表</a>
  </div>
</div>

<script>
async function remove(id) {
  if (!confirm('确定要删除该订阅者吗？')) return;
  var resp = await fetch('/admin/subscribers/' + id, { method: 'DELETE' });
  var result = await resp.json();
  if (result.ok) window.location.href = result.redirect;
}
</script>

<%- include('../_foot') %>
