<%- include('../_head') %>

<h1 class="text-3xl font-bold text-brand mb-6">新建订阅者</h1>

<div id="errorBox" class="bg-red-50 text-brand border border-red-200 rounded p-3 mb-4 max-w-lg hidden"></div>

<form class="bg-white rounded-lg shadow p-8 max-w-lg" id="createForm">
  <div class="mb-5">
    <label for="name" class="block font-semibold mb-1.5 text-warm-text">姓名</label>
    <input type="text" id="name" name="name"
           placeholder="请输入姓名" required
           class="w-full px-3 py-2.5 border border-gray-300 rounded text-base font-inherit transition-colors focus:outline-none focus:border-brand focus:ring-2 focus:ring-brand/15">
  </div>

  <div class="mb-5">
    <label for="email" class="block font-semibold mb-1.5 text-warm-text">邮箱</label>
    <input type="email" id="email" name="email"
           placeholder="your@email.com" required
           class="w-full px-3 py-2.5 border border-gray-300 rounded text-base font-inherit transition-colors focus:outline-none focus:border-brand focus:ring-2 focus:ring-brand/15">
  </div>

  <div class="mb-5">
    <label for="zipCode" class="block font-semibold mb-1.5 text-warm-text">邮编（选填）</label>
    <input type="text" id="zipCode" name="zipCode"
           placeholder="5位数字，如 10001" maxlength="5"
           class="w-full px-3 py-2.5 border border-gray-300 rounded text-base font-inherit transition-colors focus:outline-none focus:border-brand focus:ring-2 focus:ring-brand/15">
  </div>

  <div class="flex gap-3 mt-6">
    <button type="submit" class="inline-block px-4 py-2 bg-brand text-white border-none rounded text-sm font-medium cursor-pointer hover:bg-brand-dark transition-colors font-inherit">保存</button>
    <a href="/admin/subscribers" class="inline-block px-4 py-2 bg-gray-400 text-white no-underline rounded text-sm font-medium hover:bg-gray-500 transition-colors">取消</a>
  </div>
</form>

<script>
document.getElementById('createForm').addEventListener('submit', async function(e) {
  e.preventDefault();
  const formData = new FormData(this);
  const data = Object.fromEntries(formData.entries());
  const resp = await fetch('/admin/subscribers', {
    method: 'POST',
    body: JSON.stringify(data),
    headers: { 'Content-Type': 'application/json' },
  });
  const result = await resp.json();
  if (result.ok) {
    window.location.href = result.redirect;
  } else if (result.errors) {
    var box = document.getElementById('errorBox');
    box.classList.remove('hidden');
    box.innerHTML = result.errors.map(function(e) {
      return '<p>' + (e.field ? '<strong>' + e.field + '</strong>：' : '') + e.message + '</p>';
    }).join('');
  }
});
</script>

<%- include('../_foot') %>
