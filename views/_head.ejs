<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> — 缤纷厨房</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            brand: { DEFAULT: '#b33c2b', light: '#fef0ed', dark: '#922b1f' },
            warm: { bg: '#fefaf5', text: '#3d2c2c', muted: '#6b4e4e' },
          }
        }
      }
    }
  </script>
</head>
<body class="font-sans leading-relaxed text-warm-text bg-warm-bg min-h-screen flex flex-col">

  <!-- 导航栏 -->
  <nav class="bg-brand shadow-md px-6">
    <ul class="flex gap-2 max-w-4xl mx-auto list-none flex-wrap items-center">
      <% if (!locals.user) { %>
        <!-- 未登录 -->
        <li><a href="/" class="inline-block px-5 py-4 text-white no-underline font-medium rounded hover:bg-white/15 transition-colors <%- currentPage === 'home' ? 'bg-white/20' : '' %>">首页</a></li>
        <li><a href="/courses" class="inline-block px-5 py-4 text-white no-underline font-medium rounded hover:bg-white/15 transition-colors <%- currentPage === 'courses' ? 'bg-white/20' : '' %>">课程</a></li>
        <li><a href="/contact" class="inline-block px-5 py-4 text-white no-underline font-medium rounded hover:bg-white/15 transition-colors <%- currentPage === 'contact' ? 'bg-white/20' : '' %>">联系我们</a></li>
        <li class="text-white/40 px-1 py-4 select-none">|</li>
        <li><a href="/login" class="inline-block px-5 py-4 text-white no-underline font-medium rounded hover:bg-white/15 transition-colors <%- currentPage === 'login' ? 'bg-white/20' : '' %>">登录</a></li>
        <li><a href="/register" class="inline-block px-5 py-4 text-white no-underline font-medium rounded hover:bg-white/15 transition-colors <%- currentPage === 'register' ? 'bg-white/20' : '' %>">注册</a></li>
      <% } else if (locals.user.role === 'admin') { %>
        <!-- 管理员 -->
        <li><a href="/admin/users" class="inline-block px-5 py-4 text-white no-underline font-medium rounded hover:bg-white/15 transition-colors <%- currentPage === 'users' ? 'bg-white/20' : '' %>">用户管理</a></li>
        <li><a href="/admin/courses" class="inline-block px-5 py-4 text-white no-underline font-medium rounded hover:bg-white/15 transition-colors <%- currentPage === 'courses-admin' ? 'bg-white/20' : '' %>">课程管理</a></li>
        <li><a href="/admin/subscribers" class="inline-block px-5 py-4 text-white no-underline font-medium rounded hover:bg-white/15 transition-colors <%- currentPage === 'subscribers' ? 'bg-white/20' : '' %>">订阅管理</a></li>
        <li class="text-white/40 px-1 py-4 select-none">|</li>
        <li class="text-white/80 px-1 py-4 font-medium select-none">欢迎，<%= locals.user.name %></li>
        <li><a href="/logout" class="inline-block px-5 py-4 text-white no-underline font-medium rounded hover:bg-white/15 transition-colors">登出</a></li>
      <% } else { %>
        <!-- 普通用户 -->
        <li><a href="/" class="inline-block px-5 py-4 text-white no-underline font-medium rounded hover:bg-white/15 transition-colors <%- currentPage === 'home' ? 'bg-white/20' : '' %>">首页</a></li>
        <li><a href="/courses" class="inline-block px-5 py-4 text-white no-underline font-medium rounded hover:bg-white/15 transition-colors <%- currentPage === 'courses' ? 'bg-white/20' : '' %>">课程</a></li>
        <li><a href="/my-courses" class="inline-block px-5 py-4 text-white no-underline font-medium rounded hover:bg-white/15 transition-colors <%- currentPage === 'my-courses' ? 'bg-white/20' : '' %>">我的课程</a></li>
        <li><a href="/users/<%= locals.user._id %>" class="inline-block px-5 py-4 text-white no-underline font-medium rounded hover:bg-white/15 transition-colors <%- currentPage === 'profile' ? 'bg-white/20' : '' %>">个人资料</a></li>
        <li class="text-white/40 px-1 py-4 select-none">|</li>
        <li class="text-white/80 px-1 py-4 font-medium select-none">欢迎，<%= locals.user.name %></li>
        <li><a href="/logout" class="inline-block px-5 py-4 text-white no-underline font-medium rounded hover:bg-white/15 transition-colors">登出</a></li>
      <% } %>
    </ul>
  </nav>

  <!-- 主内容 -->
  <main class="flex-1 max-w-4xl w-full mx-auto my-8 px-6">

    <% /* Flash 消息 */ %>
    <% if (locals.messages) { %>
      <% if (locals.messages.error) { %>
        <div class="bg-red-50 text-brand border border-red-200 rounded px-4 py-3 mb-4 font-medium"><%= locals.messages.error %></div>
      <% } %>
      <% if (locals.messages.success) { %>
        <div class="bg-green-50 text-green-700 border border-green-200 rounded px-4 py-3 mb-4 font-medium"><%= locals.messages.success %></div>
      <% } %>
    <% } %>

    <% /* 表单校验错误（非 flash） */ %>
    <% if (locals.errors && locals.errors.length) { %>
      <div class="bg-red-50 text-brand border border-red-200 rounded p-3 mb-4 max-w-lg">
        <% locals.errors.forEach(function(e) { %>
          <p class="mb-1 last:mb-0"><% if (e.field) { %><strong><%= e.field %></strong>：<% } %><%= e.message %></p>
        <% }); %>
      </div>
    <% } %>
