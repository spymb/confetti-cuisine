<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> — 缤纷厨房</title>
  <link rel="stylesheet" href="/public/css/style.css">
</head>
<body>
  <nav>
    <ul>
      <% if (!locals.user) { %>
        <!-- 未登录：显示前台链接（访客浏览学校） -->
        <li><a href="/" <%- currentPage === 'home' ? 'class="active"' : '' %>>首页</a></li>
        <li><a href="/courses" <%- currentPage === 'courses' ? 'class="active"' : '' %>>课程</a></li>
        <li><a href="/contact" <%- currentPage === 'contact' ? 'class="active"' : '' %>>联系我们</a></li>
        <li class="nav-divider">|</li>
        <li><a href="/login" <%- currentPage === 'login' ? 'class="active"' : '' %>>登录</a></li>
        <li><a href="/register" <%- currentPage === 'register' ? 'class="active"' : '' %>>注册</a></li>
      <% } else if (locals.user.role === 'admin') { %>
        <!-- 已登录管理员：显示管理链接 -->
        <li><a href="/admin/users" <%- currentPage === 'users' ? 'class="active"' : '' %>>用户管理</a></li>
        <li><a href="/admin/courses" <%- currentPage === 'courses-admin' ? 'class="active"' : '' %>>课程管理</a></li>
        <li><a href="/admin/subscribers" <%- currentPage === 'subscribers' ? 'class="active"' : '' %>>订阅管理</a></li>
        <li class="nav-divider">|</li>
        <li class="nav-text">欢迎，<%= locals.user.name %></li>
        <li><a href="/logout">登出</a></li>
      <% } else { %>
        <!-- 已登录普通用户：显示个人资料入口 -->
        <li><a href="/users/<%= locals.user._id %>" <%- currentPage === 'profile' ? 'class="active"' : '' %>>个人资料</a></li>
        <li class="nav-divider">|</li>
        <li class="nav-text">欢迎，<%= locals.user.name %></li>
        <li><a href="/logout">登出</a></li>
      <% } %>
    </ul>
  </nav>
  <main>
    <% /* Flash 消息展示区 */ %>
    <% if (locals.messages) { %>
      <% if (locals.messages.error) { %>
        <div class="flash flash-error"><%= locals.messages.error %></div>
      <% } %>
      <% if (locals.messages.success) { %>
        <div class="flash flash-success"><%= locals.messages.success %></div>
      <% } %>
    <% } %>
    <% /* errors 数组用于表单校验错误（非 flash） */ %>
    <% if (locals.errors && locals.errors.length) { %>
      <div class="error-box">
        <% locals.errors.forEach(function(e) { %>
          <p><% if (e.field) { %><strong><%= e.field %></strong>：<% } %><%= e.message %></p>
        <% }); %>
      </div>
    <% } %>
