<%- include('_head') %>

<h2 class="page-title">联系我们</h2>
<p style="margin-bottom: 1.5rem; color: #6b4e4e;">
  对我们的课程有疑问？我们很乐意倾听！
</p>

<form class="contact-form" action="/subscribe" method="POST">
  <% if (typeof error !== 'undefined' && error) { %>
    <div style="background: #fff0f0; color: #b33c2b; border: 1px solid #f5c6cb; padding: 0.75rem 1rem; border-radius: 4px; margin-bottom: 1rem;">
      ⚠️ <%= error %>
    </div>
  <% } %>

  <div class="form-group">
    <label for="name">姓名</label>
    <input type="text" id="name" name="name"
           value="<%= typeof formData !== 'undefined' && formData.name ? formData.name : '' %>"
           placeholder="请输入您的姓名" required>
  </div>

  <div class="form-group">
    <label for="email">邮箱</label>
    <input type="email" id="email" name="email"
           value="<%= typeof formData !== 'undefined' && formData.email ? formData.email : '' %>"
           placeholder="your@email.com" required>
  </div>

  <div class="form-group">
    <label for="zipCode">邮编（选填）</label>
    <input type="text" id="zipCode" name="zipCode"
           value="<%= typeof formData !== 'undefined' && formData.zipCode ? formData.zipCode : '' %>"
           placeholder="5位数字，如 10001" pattern="\d{5}" maxlength="5">
  </div>

  <button type="submit">订阅</button>
</form>

<aside class="contact-info">
  <h3>来访地址</h3>
  <p><strong>地址：</strong> 风味小镇意面路 123 号</p>
  <p><strong>电话：</strong> (555) 123-4567</p>
  <p><strong>邮箱：</strong> hello@confetti-cuisine.example.com</p>
</aside>

<%- include('_foot') %>
