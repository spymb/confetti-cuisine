<%- include('_head') %>

<h1 class="text-3xl font-bold text-brand mb-6">联系我们</h1>
<p class="mb-6 text-warm-muted">
  对我们的课程有疑问？我们很乐意倾听！
</p>

<form class="bg-white rounded-lg shadow p-8 max-w-lg" action="/subscribe" method="POST">
  <% if (typeof error !== 'undefined' && error) { %>
    <div class="bg-red-50 text-brand border border-red-200 rounded p-3 mb-4">⚠️ <%= error %></div>
  <% } %>

  <div class="mb-5">
    <label for="name" class="block font-semibold mb-1.5 text-warm-text">姓名</label>
    <input type="text" id="name" name="name"
           value="<%= typeof formData !== 'undefined' && formData.name ? formData.name : '' %>"
           placeholder="请输入您的姓名" required
           class="w-full px-3 py-2.5 border border-gray-300 rounded text-base font-inherit transition-colors focus:outline-none focus:border-brand focus:ring-2 focus:ring-brand/15">
  </div>

  <div class="mb-5">
    <label for="email" class="block font-semibold mb-1.5 text-warm-text">邮箱</label>
    <input type="email" id="email" name="email"
           value="<%= typeof formData !== 'undefined' && formData.email ? formData.email : '' %>"
           placeholder="your@email.com" required
           class="w-full px-3 py-2.5 border border-gray-300 rounded text-base font-inherit transition-colors focus:outline-none focus:border-brand focus:ring-2 focus:ring-brand/15">
  </div>

  <div class="mb-5">
    <label for="zipCode" class="block font-semibold mb-1.5 text-warm-text">邮编（选填）</label>
    <input type="text" id="zipCode" name="zipCode"
           value="<%= typeof formData !== 'undefined' && formData.zipCode ? formData.zipCode : '' %>"
           placeholder="5位数字，如 10001" pattern="\d{5}" maxlength="5"
           class="w-full px-3 py-2.5 border border-gray-300 rounded text-base font-inherit transition-colors focus:outline-none focus:border-brand focus:ring-2 focus:ring-brand/15">
  </div>

  <button type="submit" class="px-7 py-2.5 bg-brand text-white border-none rounded-md text-base cursor-pointer hover:bg-brand-dark transition-colors font-inherit">订阅</button>
</form>

<aside class="mt-8 p-6 bg-white rounded-lg shadow">
  <h3 class="text-brand text-lg font-bold mb-2">来访地址</h3>
  <p><strong>地址：</strong> 风味小镇意面路 123 号</p>
  <p><strong>电话：</strong> (555) 123-4567</p>
  <p><strong>邮箱：</strong> hello@confetti-cuisine.example.com</p>
</aside>

<%- include('_foot') %>
