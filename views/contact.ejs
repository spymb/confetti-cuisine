<%- include('_head') %>

<h2 class="page-title">联系我们</h2>
<p style="margin-bottom: 1.5rem; color: #6b4e4e;">
  对我们的课程有疑问？我们很乐意倾听！
</p>

<form class="contact-form" action="/subscribe" method="POST">
  <div class="form-group">
    <label for="name">姓名</label>
    <input type="text" id="name" name="name" placeholder="请输入您的姓名" required>
  </div>

  <div class="form-group">
    <label for="email">邮箱</label>
    <input type="email" id="email" name="email" placeholder="your@email.com" required>
  </div>

  <div class="form-group">
    <label for="subject">主题</label>
    <input type="text" id="subject" name="subject" placeholder="我们有什么可以帮您？">
  </div>

  <div class="form-group">
    <label for="message">留言</label>
    <textarea id="message" name="message" placeholder="告诉我们您的烹饪兴趣……" required></textarea>
  </div>

  <button type="submit">发送消息</button>
</form>

<aside class="contact-info">
  <h3>来访地址</h3>
  <p><strong>地址：</strong> 风味小镇意面路 123 号</p>
  <p><strong>电话：</strong> (555) 123-4567</p>
  <p><strong>邮箱：</strong> hello@confetti-cuisine.example.com</p>
  <p style="margin-top: 0.75rem; font-style: italic; color: #999;">
    提示：表单提交为演示功能，数据不会被实际存储。
  </p>
</aside>

<%- include('_foot') %>
