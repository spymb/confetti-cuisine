<%- include('_head') %>

<h2 class="page-title">订阅者列表</h2>

<% if (subscribers.length === 0) { %>
  <p style="color: #6b4e4e;">暂无订阅者。</p>
<% } else { %>
  <table class="subscribers-table">
    <thead>
      <tr>
        <th>姓名</th>
        <th>邮箱</th>
        <th>邮编</th>
        <th>订阅时间</th>
      </tr>
    </thead>
    <tbody>
      <% subscribers.forEach(function(sub) { %>
        <tr>
          <td><%= sub.name %></td>
          <td><%= sub.email %></td>
          <td><%= sub.zipCode || '—' %></td>
          <td><%= new Date(sub.createdAt).toLocaleString('zh-CN') %></td>
        </tr>
      <% }); %>
    </tbody>
  </table>
<% } %>

<%- include('_foot') %>
